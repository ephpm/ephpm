# Build artifacts
target/

# PHP SDK (downloaded by cargo xtask php-sdk from github.com/ephpm/php-sdk releases)
/php-sdk/

# sqld binary cache (downloaded by cargo xtask release)
/sqld-cache/

# Local tool binaries (downloaded by cargo xtask e2e-install)
/bin/

# IDE
.idea/
.vscode/
*.swp

# Claude Code worktrees
.claude/worktrees/

# Claude Code personal/local permissions (project-shared rules go in .claude/settings.json)
.claude/settings.local.json

# Tilt state
.tilt-dev/

# Hugo build output (cargo xtask docs build)
/site/public/
/site/resources/_gen/
/site/.hugo_build.lock

# OS
.DS_Store
Thumbs.db
